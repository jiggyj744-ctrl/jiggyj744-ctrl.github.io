# /etc/jauction-share-blog-publisher.env
#
# 이 파일은 런타임 서버에만 둔다. Git에 실제 키를 저장하지 않는다.

LLM_PROXY_BASE_URL=http://127.0.0.1:8302/v1
LLM_PROXY_MODEL=gemini-pro
LLM_PROXY_API_KEY=

# Git push 권한은 런타임 repo의 remote/credential helper 또는 SSH deploy key로 설정한다.
GIT_AUTHOR_NAME=jauction-publisher
GIT_AUTHOR_EMAIL=jauction-publisher@users.noreply.github.com
